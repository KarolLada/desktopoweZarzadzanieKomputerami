<Window x:Class="LabManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberCafe Management System"
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <Style TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="TitleText">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Margin" Value="0,5,0,0"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>

    </Window.Resources>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <DockPanel Grid.Row="0" Background="#2D2D30" LastChildFill="False" Height="45">

            <TextBlock Text="CyberCafe Control Panel"
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="10,0"
                       FontSize="14"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Zaloguj"/>
                <Button Content="Wyloguj"/>
                <Button Content="Raporty"/>
                <Button Content="Ustawienia"/>
            </StackPanel>

        </DockPanel>

        <!-- MAIN AREA -->
        <TabControl Grid.Row="1">

            <!-- DASHBOARD -->
            <TabItem Header="Dashboard">
                <Grid Margin="10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Status systemu" Style="{StaticResource TitleText}"/>
                        <TextBlock Text="Online PC: 12"/>
                        <TextBlock Text="Offline PC: 3"/>
                        <TextBlock Text="Aktywne sesje: 7"/>
                        <TextBlock Text="Przychód dzienny: 420 PLN"/>
                    </StackPanel>

                    <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Margin="10">
                        <TextBlock Text="Wykres / statystyki (placeholder)"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                </Grid>
            </TabItem>

            <!-- COMPUTERS -->
            <TabItem Header="Komputery">
                <Grid Margin="10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LISTA -->
                    <DataGrid Grid.Column="0" Name="ComputersGrid">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nazwa" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="IP (dynamiczne)" Binding="{Binding IP}" Width="*"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                            <DataGridTextColumn Header="Grupa" Binding="{Binding Group}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- PANEL AKCJI -->
                    <StackPanel Grid.Column="1" Margin="10">

                        <TextBlock Text="Akcje komputera" Style="{StaticResource TitleText}"/>

                        <Button Content="Uruchom sesję"/>
                        <Button Content="Zakończ sesję"/>
                        <Button Content="Zdalny pulpit"/>
                        <Button Content="Restart"/>
                        <Button Content="Wyłącz"/>
                        <Button Content="Zablokuj"/>

                        <Separator Margin="0,10"/>

                        <TextBlock Text="Grupy komputerów"/>
                        <ComboBox>
                            <ComboBoxItem Content="Gaming"/>
                            <ComboBoxItem Content="IRC"/>
                            <ComboBoxItem Content="Grafika"/>
                        </ComboBox>

                    </StackPanel>

                </Grid>
            </TabItem>

            <!-- USERS & ACCOUNTS -->
            <TabItem Header="Użytkownicy">
                <Grid Margin="10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>

                    <DataGrid Grid.Column="0" Name="UsersGrid">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Login" Binding="{Binding Login}" Width="*"/>
                            <DataGridTextColumn Header="Typ konta" Binding="{Binding AccountType}" Width="*"/>
                            <DataGridTextColumn Header="Saldo" Binding="{Binding Balance}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Column="1" Margin="10">

                        <TextBlock Text="Konto użytkownika" Style="{StaticResource TitleText}"/>

                        <TextBlock Text="Typ konta:"/>
                        <ComboBox>
                            <ComboBoxItem Content="Czasowe"/>
                            <ComboBoxItem Content="Gotówkowe"/>
                            <ComboBoxItem Content="Debetowe"/>
                            <ComboBoxItem Content="Administracyjne"/>
                        </ComboBox>

                        <TextBlock Text="Login"/>
                        <TextBox/>

                        <TextBlock Text="Hasło"/>
                        <PasswordBox/>
 
                        <Button Content="Dodaj użytkownika"/>
                        <Button Content="Zapisz zmiany"/>

                    </StackPanel>

                </Grid>
            </TabItem>

            
        </TabControl>

    </Grid>
</Window>
